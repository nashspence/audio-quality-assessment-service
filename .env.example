SERVICE_PORT=8000
LOG_LEVEL=info
PREFER_GPU=true
REQUIRE_GPU_FOR_NISQA=true
ENABLE_DNSMOS=false
MODEL_CACHE_DIR=/cache
NISQA_BATCH_SIZE=16
WORKSPACE_DIR=/workspace
ROLLING_WINDOW_SECONDS=6.0
ROLLING_HOP_SECONDS=3.0
BLIND_SNR_BAD_DB=5.0
BLIND_SNR_GOOD_DB=25.0
BOUNDARY_NEAR_SECONDS=0.35
BOUNDARY_SAFE_SECONDS=1.0
OVERLAP_WARN_FRACTION=0.1
OVERLAP_HEAVY_FRACTION=0.35
SPEAKER_CONFIDENCE_LOW=0.5
SPEAKER_CONFIDENCE_HIGH=0.85
ASR_CONFIDENCE_LOW=0.6
ASR_CONFIDENCE_HIGH=0.9
ASR_GAP_GOOD_RATE=0.05
ASR_GAP_BAD_RATE=0.25
ASR_DENSITY_LOW_WPS=0.8
ASR_DENSITY_HIGH_WPS=3.5
SPELLING_EDIT_WARN_RATE=0.12
NON_SPEECH_DOMINANCE_WARN=0.6
EMOTION_INSTABILITY_WARN=0.45
ENHANCEMENT_SHIFT_WARN=0.3
LOW_CONFIDENCE_THRESHOLD=0.5
WEIGHT_AUDIO_QUALITY=3.0
WEIGHT_BOUNDARY=1.0
WEIGHT_OVERLAP=1.0
WEIGHT_SPEAKER=1.0
WEIGHT_ASR=2.0
WEIGHT_SPELLING=1.0
WEIGHT_SED=1.0
WEIGHT_EMOTION=1.0
WEIGHT_ENHANCEMENT=1.0
WEIGHT_CONTEXT=1.0
WEIGHT_INTEGRITY=2.0
